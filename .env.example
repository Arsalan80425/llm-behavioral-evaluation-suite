# LLM Evaluation & Enterprise RAG Reliability Lab — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env with real API keys. It is listed in .gitignore.
#
# USE_REAL_LLM=true should only be set in your local .env or in deployment
# secrets (e.g., GitHub Actions secrets). Never commit with a real key value.

# ── Groq (optional — mock mode works without this) ──────────────────────────
GROQ_API_KEY=

# Primary model for Groq generation (verified locally: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallback model if the primary is unavailable
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant

# ── Evaluation mode ─────────────────────────────────────────────────────────
# Set to true ONLY for local or CI runs where a real Groq key is available.
# The GitHub Pages static demo always runs with exported mock data — it never
# reads this variable and never calls Groq from browser JavaScript.
USE_REAL_LLM=false

# Optional: enable LLM-as-judge scoring (requires USE_REAL_LLM=true + key)
USE_LLM_JUDGE=false
